#include <iostream>
using namespace std;
int main() {
    int i, j, c = 1;
    for (i = 1; i <= 5; i++, c += 2) {
        for (j = 0; j < 5 - i; j++) {
            cout << " ";
        }
        for (j = 1; j <= c; j++) {
            if (i == 5 || j == 1 || j == c)
                cout << "*";
            else
                cout << " ";
        }
        cout << "\n";
    }
    return 0;
}

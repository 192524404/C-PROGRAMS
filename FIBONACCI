#include <iostream>
using namespace std;
int main() {
    int n, a = 0, b = 1, c, i = 1;
    cout << "Enter the number of terms: ";
    cin >> n;
    cout << "Fibonacci Series\n";
    while (i <= n) {
        cout << a << " ";
        c = a + b;
        a = b;
        b = c;
        i++;
    }
    return 0;
}
